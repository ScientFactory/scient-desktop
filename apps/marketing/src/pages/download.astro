---
import { faApple, faLinux, faWindows } from "@fortawesome/free-brands-svg-icons";

import DownloadAssetCard from "../components/DownloadAssetCard.astro";
import Layout from "../layouts/Layout.astro";
import { LATEST_RELEASE_URL, RELEASES_URL } from "../lib/releases";

const platformIcons = {
  macOS: faApple,
  Windows: faWindows,
  Linux: faLinux,
};

function iconData(platform: keyof typeof platformIcons) {
  const [width, height, , , pathData] = platformIcons[platform].icon;
  return {
    width,
    height,
    path: Array.isArray(pathData) ? pathData[0] : pathData,
  };
}

const macIcon = iconData("macOS");
const windowsIcon = iconData("Windows");
const linuxIcon = iconData("Linux");
---

<Layout
  theme="light"
  title="Download Scient for macOS, Windows, and Linux"
  description="Download the latest Scient desktop app for macOS, Windows, or Linux from ScientFactory's official GitHub release."
>
  <div class="download-page">
  <section class="download-hero" aria-labelledby="download-heading">
    <div class="download-hero__copy">
      <p class="download-kicker">Scient desktop</p>
      <h1 id="download-heading">Download Scient</h1>
      <p class="download-intro">
        Choose your platform. Every installer is delivered directly from ScientFactory's official GitHub release.
      </p>
    </div>

    <div class="release-status" data-release-state="loading" aria-live="polite" aria-atomic="true">
      <span class="release-status__dot" aria-hidden="true"></span>
      <span id="release-status-copy">Checking the latest release&hellip;</span>
      <button id="release-retry" class="release-status__retry" type="button" hidden>Try again</button>
    </div>
  </section>

  <section class="early-access-note" aria-labelledby="early-access-title">
    <div>
      <p class="early-access-note__eyebrow">Early access</p>
      <h2 id="early-access-title">A transparent first release</h2>
    </div>
    <p>
      Early-access installers may be unsigned. Windows updates continue inside Scient after you confirm the operating-system warning. On macOS, Scient downloads the update and opens it in Finder so you can replace the app safely.
    </p>
  </section>

  <div class="platform-grid" aria-label="Scient downloads by platform">
    <section class="platform-section platform-section--burgundy" id="macos" aria-labelledby="macos-title">
      <div class="platform-section__header">
        <span class="platform-section__icon" aria-hidden="true">
          <svg viewBox={`0 0 ${macIcon.width} ${macIcon.height}`}><path d={macIcon.path}></path></svg>
        </span>
        <div>
          <h2 id="macos-title">macOS</h2>
          <p>Apple Silicon and Intel</p>
        </div>
      </div>
      <div class="platform-section__downloads">
        <DownloadAssetCard
          assetKey="macArm64"
          title="Apple Silicon"
          detail="M1, M2, M3, and newer"
          format="DMG"
          tone="burgundy"
        />
        <DownloadAssetCard
          assetKey="macX64"
          title="Intel"
          detail="Intel-based Macs"
          format="DMG"
          tone="burgundy"
        />
      </div>
    </section>

    <section class="platform-section platform-section--slate" id="windows" aria-labelledby="windows-title">
      <div class="platform-section__header">
        <span class="platform-section__icon" aria-hidden="true">
          <svg viewBox={`0 0 ${windowsIcon.width} ${windowsIcon.height}`}><path d={windowsIcon.path}></path></svg>
        </span>
        <div>
          <h2 id="windows-title">Windows</h2>
          <p>64-bit Windows installer</p>
        </div>
      </div>
      <div class="platform-section__downloads">
        <DownloadAssetCard
          assetKey="windowsX64"
          title="Windows installer"
          detail="For 64-bit Windows PCs"
          format="EXE"
          tone="slate"
        />
      </div>
    </section>

    <section class="platform-section platform-section--burgundy" id="linux" aria-labelledby="linux-title">
      <div class="platform-section__header">
        <span class="platform-section__icon" aria-hidden="true">
          <svg viewBox={`0 0 ${linuxIcon.width} ${linuxIcon.height}`}><path d={linuxIcon.path}></path></svg>
        </span>
        <div>
          <h2 id="linux-title">Linux</h2>
          <p>x64 AppImage</p>
        </div>
      </div>
      <div class="platform-section__downloads">
        <DownloadAssetCard
          assetKey="linuxX64"
          title="Linux AppImage"
          detail="Portable x64 application"
          format="APPIMAGE"
          tone="burgundy"
        />
      </div>
    </section>
  </div>

  <section class="install-help" aria-labelledby="install-help-title">
    <div class="install-help__heading">
      <p class="download-kicker">First launch</p>
      <h2 id="install-help-title">Install with confidence</h2>
    </div>
    <div class="install-help__steps">
      <article>
        <span>01</span>
        <h3>macOS</h3>
        <p>Open the DMG and move Scient to Applications. If macOS blocks the first launch, Control-click Scient, choose Open, then confirm. Unsigned updates open in Finder for the same replacement step.</p>
      </article>
      <article>
        <span>02</span>
        <h3>Windows</h3>
        <p>Open the installer. If SmartScreen appears, verify that the file came from this page before choosing More info. Later updates download and launch from inside Scient.</p>
      </article>
      <article>
        <span>03</span>
        <h3>Linux</h3>
        <p>Mark the AppImage as executable, then open it. From a terminal: <code>chmod +x Scient-*.AppImage</code>.</p>
      </article>
    </div>
  </section>

  <div class="release-links">
    <a id="release-notes-link" href={LATEST_RELEASE_URL} target="_blank" rel="noopener noreferrer">
      Release notes <span aria-hidden="true">&#8599;</span>
    </a>
    <a id="checksums-link" href={LATEST_RELEASE_URL} target="_blank" rel="noopener noreferrer" hidden>
      SHA-256 checksums <span aria-hidden="true">&#8599;</span>
    </a>
    <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer">
      All releases <span aria-hidden="true">&#8599;</span>
    </a>
  </div>
  </div>
</Layout>

<script>
  import {
    fetchLatestRelease,
    findChecksumAsset,
    findDownloadAsset,
    formatFileSize,
    LATEST_RELEASE_URL,
    type DownloadAssetKey,
  } from "../lib/releases";

  const cards = [...document.querySelectorAll<HTMLAnchorElement>("[data-download-asset]")];
  const status = document.querySelector<HTMLElement>("[data-release-state]");
  const statusCopy = document.getElementById("release-status-copy");
  const retry = document.querySelector<HTMLButtonElement>("#release-retry");
  const releaseNotes = document.querySelector<HTMLAnchorElement>("#release-notes-link");
  const checksums = document.querySelector<HTMLAnchorElement>("#checksums-link");

  cards.forEach((card) => {
    card.addEventListener("click", (event) => {
      if (card.dataset.state !== "available") event.preventDefault();
    });
  });

  function updateStatus(state: "loading" | "ready" | "error", copy: string): void {
    if (status) status.dataset.releaseState = state;
    if (statusCopy) statusCopy.textContent = copy;
    if (retry) retry.hidden = state !== "error";
  }

  function resetCards(): void {
    cards.forEach((card) => {
      card.dataset.state = "loading";
      card.setAttribute("aria-disabled", "true");
      card.removeAttribute("href");
      const detail = card.querySelector<HTMLElement>("[data-download-detail]");
      if (detail?.dataset.defaultDetail) detail.textContent = detail.dataset.defaultDetail;
    });
    if (releaseNotes) releaseNotes.href = LATEST_RELEASE_URL;
    if (checksums) {
      checksums.href = LATEST_RELEASE_URL;
      checksums.hidden = true;
    }
  }

  function markCardsUnavailable(copy: string): void {
    cards.forEach((card) => {
      card.dataset.state = "unavailable";
      card.setAttribute("aria-disabled", "true");
      card.removeAttribute("href");
      const detail = card.querySelector<HTMLElement>("[data-download-detail]");
      if (detail) detail.textContent = copy;
    });
  }

  async function loadRelease(force = false): Promise<void> {
    resetCards();
    updateStatus("loading", "Checking the latest release…");

    const controller = new AbortController();
    const timeout = window.setTimeout(() => controller.abort(), 10_000);

    try {
      const release = await fetchLatestRelease({ signal: controller.signal, force });
      const published = new Intl.DateTimeFormat("en", {
        year: "numeric",
        month: "short",
        day: "numeric",
      }).format(new Date(release.published_at));

      let availableCount = 0;
      cards.forEach((card) => {
        const key = card.dataset.downloadAsset as DownloadAssetKey | undefined;
        if (!key) return;
        const asset = findDownloadAsset(release, key);
        const detail = card.querySelector<HTMLElement>("[data-download-detail]");

        if (!asset) {
          card.dataset.state = "unavailable";
          if (detail) detail.textContent = `Not included in ${release.tag_name}`;
          return;
        }

        availableCount += 1;
        card.href = asset.browser_download_url;
        card.dataset.state = "available";
        card.removeAttribute("aria-disabled");
        if (detail) {
          const base = detail.dataset.defaultDetail ?? "Installer";
          const size = formatFileSize(asset.size);
          detail.textContent = size ? `${base} · ${size}` : base;
        }
      });

      if (releaseNotes) releaseNotes.href = release.html_url;
      const checksumAsset = findChecksumAsset(release);
      if (checksums && checksumAsset) {
        checksums.href = checksumAsset.browser_download_url;
        checksums.hidden = false;
      }

      if (availableCount === cards.length) {
        updateStatus("ready", `${release.tag_name} · Published ${published}`);
      } else if (availableCount > 0) {
        updateStatus("error", `${release.tag_name} is missing one or more installers.`);
      } else {
        updateStatus("error", "The latest release does not contain desktop installers yet.");
      }
    } catch {
      markCardsUnavailable("Temporarily unavailable");
      updateStatus("error", "Downloads are temporarily unavailable. You can retry or view all releases.");
    } finally {
      window.clearTimeout(timeout);
    }
  }

  retry?.addEventListener("click", () => void loadRelease(true));
  void loadRelease();
</script>

<style>
  .download-page {
    width: min(100%, 80rem);
    margin-inline: auto;
    padding: clamp(2.5rem, 5vw, 4.75rem) var(--page-gutter) clamp(5rem, 8vw, 8rem);
  }

  .download-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 2rem;
    padding-bottom: clamp(2.5rem, 5vw, 4.25rem);
    border-bottom: 1px solid var(--line);
  }

  .download-kicker,
  .early-access-note__eyebrow {
    margin: 0 0 0.85rem;
    color: var(--burgundy);
    font-size: 0.78rem;
    font-weight: 650;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 1.15rem;
    color: var(--ink);
    font-size: clamp(3rem, 7vw, 6.4rem);
    font-weight: 450;
    letter-spacing: -0.065em;
    line-height: 0.92;
  }

  .download-intro {
    max-width: 40rem;
    margin-bottom: 0;
    color: var(--ink-muted);
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.55;
  }

  .release-status {
    min-height: 2.65rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.72rem 0.9rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-muted);
    background: var(--surface-muted);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .release-status__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--slate);
    box-shadow: 0 0 0 0.24rem color-mix(in srgb, var(--slate) 12%, transparent);
  }

  .release-status[data-release-state="ready"] .release-status__dot {
    background: #2f7751;
    box-shadow: 0 0 0 0.24rem rgba(47, 119, 81, 0.12);
  }

  .release-status[data-release-state="error"] .release-status__dot {
    background: var(--burgundy);
    box-shadow: 0 0 0 0.24rem color-mix(in srgb, var(--burgundy) 12%, transparent);
  }

  .release-status__retry {
    min-height: 1.75rem;
    border: 0;
    padding: 0.25rem 0.1rem;
    background: transparent;
    color: var(--burgundy);
    font: inherit;
    font-weight: 650;
    text-decoration: underline;
    text-underline-offset: 0.2em;
    cursor: pointer;
  }

  .release-status__retry:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 4px;
  }

  .early-access-note {
    display: grid;
    grid-template-columns: minmax(13rem, 0.7fr) minmax(0, 1.3fr);
    gap: clamp(2rem, 6vw, 7rem);
    margin-block: clamp(2.5rem, 5vw, 4rem);
    padding: clamp(1.5rem, 3vw, 2.2rem);
    border-left: 3px solid var(--burgundy);
    background: var(--burgundy-soft);
  }

  .early-access-note h2 {
    margin-bottom: 0;
    font-size: clamp(1.35rem, 2.2vw, 1.8rem);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.1;
  }

  .early-access-note > p {
    max-width: 44rem;
    margin-bottom: 0;
    color: var(--ink-muted);
    line-height: 1.62;
  }

  .platform-grid {
    width: min(100%, 66rem);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(2rem, 5vw, 4.5rem);
    margin-inline: auto;
  }

  .platform-section {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr);
    align-content: center;
    align-items: center;
    column-gap: 1.25rem;
    scroll-margin-top: 2rem;
    padding-block: clamp(1.25rem, 2.4vw, 1.75rem);
    border-top: 1px solid var(--line);
  }

  .platform-section:first-child {
    grid-row: span 2;
    border-bottom: 1px solid var(--line);
  }

  .platform-section:last-child {
    border-bottom: 1px solid var(--line);
  }

  .platform-section:target {
    background: color-mix(in srgb, var(--burgundy-soft) 58%, transparent);
  }

  .platform-section__header {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 0;
    padding: 0 0.5rem;
  }

  .platform-section__icon {
    width: 2.55rem;
    height: 2.55rem;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    border-radius: 0.55rem;
    background: var(--burgundy-soft);
    color: var(--burgundy);
  }

  .platform-section--slate .platform-section__icon {
    background: var(--slate-soft);
    color: var(--slate);
  }

  .platform-section__icon svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }

  .platform-section__header h2 {
    margin-bottom: 0.18rem;
    font-size: 1.25rem;
    font-weight: 550;
    letter-spacing: -0.025em;
  }

  .platform-section__header p {
    margin-bottom: 0;
    color: var(--ink-dim);
    font-size: 0.8rem;
  }

  .platform-section__downloads {
    display: grid;
    gap: 0.65rem;
  }

  .install-help {
    margin-top: clamp(4rem, 7vw, 6.5rem);
    padding-top: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--line);
  }

  .install-help__heading {
    margin-bottom: 2.1rem;
  }

  .install-help__heading h2 {
    margin-bottom: 0;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 450;
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .install-help__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }

  .install-help article {
    padding-top: 1rem;
    border-top: 2px solid var(--line);
  }

  .install-help article > span {
    display: block;
    margin-bottom: 1.5rem;
    color: var(--burgundy);
    font-size: 0.75rem;
    font-weight: 650;
    letter-spacing: 0.08em;
  }

  .install-help h3 {
    margin-bottom: 0.7rem;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .install-help article p {
    margin-bottom: 0;
    color: var(--ink-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  code {
    padding: 0.08rem 0.28rem;
    border-radius: 0.25rem;
    background: var(--surface-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.84em;
  }

  .release-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 3rem;
    color: var(--ink-dim);
    font-size: 0.82rem;
  }

  .release-links a {
    padding-bottom: 0.15rem;
    border-bottom: 1px solid currentColor;
    transition: color 220ms var(--ease-out);
  }

  .release-links a:hover {
    color: var(--burgundy);
  }

  .release-links a:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 4px;
  }

  @media (max-width: 820px) {
    .download-hero,
    .early-access-note {
      grid-template-columns: 1fr;
    }

    .download-hero {
      align-items: start;
    }

    .release-status {
      width: fit-content;
      white-space: normal;
    }

    .early-access-note {
      gap: 1rem;
    }

    .platform-grid,
    .install-help__steps {
      grid-template-columns: 1fr;
    }

    .platform-section {
      grid-template-columns: 1fr;
      padding-block: 1.35rem;
    }

    .platform-section:first-child {
      grid-row: auto;
      border-bottom: 0;
    }

    .platform-section__header {
      margin-bottom: 0.9rem;
      padding: 0 0.25rem;
    }
  }

  @media (max-width: 600px) {
    .download-page {
      padding-top: 1.5rem;
    }

    h1 {
      font-size: clamp(3rem, 16vw, 4.4rem);
    }

    .release-status {
      align-items: flex-start;
    }
  }
</style>
